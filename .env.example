# ─────────────────────────────────────────────────────────────
# GH Hostels Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to client, server-only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── UPSTASH REDIS ──────────────────────────────────────────────
# Found in: Upstash Console → Database → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# ── VERCEL ────────────────────────────────────────────────────
# Used for programmatic custom domain management
VERCEL_ACCESS_TOKEN=your-vercel-token-here
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_TEAM_ID=your-vercel-team-id  # optional, for team projects

# ── ARKESEL (SMS Gateway — Ghana) ─────────────────────────────
ARKESEL_API_KEY=your-arkesel-api-key

# ── PAYSTACK (Payments — MoMo + Card) ─────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-key-here
PAYSTACK_SECRET_KEY=sk_test_your-key-here

# Platform SaaS subscription plan codes. One-time bootstrap via
# POST /api/admin/paystack/bootstrap-plans (platform-admin only). Paste the
# returned codes below, then redeploy.
PAYSTACK_PLAN_STARTER=PLN_xxx
PAYSTACK_PLAN_GROWTH=PLN_xxx

# ── RESEND (Email) ─────────────────────────────────────────────
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=no-reply@updates.gh-hostels.com

# ── VAPI (Voice AI Agent) ─────────────────────────────────────
VAPI_API_KEY=your-vapi-api-key
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret

# ── OPENAI (Embeddings for AI knowledge base) ─────────────────
OPENAI_API_KEY=sk-your-openai-key

# ── ANTHROPIC (Claude — AI Agent LLM) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ── TRIGGER.DEV (Background Jobs) ─────────────────────────────
TRIGGER_SECRET_KEY=your-trigger-secret-key

# ── APP ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=gh-hostels.com
NODE_ENV=development
