# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — NEVER expose to the browser. Used only in API Routes / Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → your Redis database → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── App domain ────────────────────────────────────────────────────────────────
# The root domain of the platform (without protocol or www)
# Used for subdomain routing: {slug}.abrempong.com
NEXT_PUBLIC_APP_DOMAIN=abrempong.com
NEXT_PUBLIC_APP_URL=https://abrempong.com

# ── Vercel (for custom domain provisioning) ───────────────────────────────────
# Get from: https://vercel.com/account/tokens
VERCEL_API_TOKEN=your-vercel-token
VERCEL_TEAM_ID=your-team-id          # optional — for team accounts
VERCEL_PROJECT_ID=your-project-id

# ── Arkesel (SMS gateway — Ghana) ─────────────────────────────────────────────
# Get from: https://developers.arkesel.com
ARKESEL_API_KEY=your-arkesel-key
ARKESEL_SENDER_ID=AbrempHMS          # max 11 chars, registered with Arkesel

# ── Paystack (MoMo payments) ──────────────────────────────────────────────────
# Get from: https://dashboard.paystack.com → Settings → API Keys
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your-key
PAYSTACK_SECRET_KEY=sk_live_your-key

# ── Resend (transactional email) ──────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-key
RESEND_FROM_EMAIL=no-reply@abrempong.com

# ── Web Push / VAPID ──────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_* key is safe to expose to the browser (it's a public key)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@abrempong.com

# ── Trigger.dev (background jobs) ─────────────────────────────────────────────
# Get from: https://cloud.trigger.dev → your project → API keys
TRIGGER_SECRET_KEY=tr_dev_your-key
NEXT_PUBLIC_TRIGGER_PUBLIC_API_KEY=pk_dev_your-key

# ── Vapi (AI voice agent — Phase 4) ──────────────────────────────────────────
VAPI_API_KEY=your-vapi-key
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your-vapi-public-key

# ── OpenAI (embeddings for AI knowledge base — Phase 4) ──────────────────────
OPENAI_API_KEY=sk-your-openai-key
