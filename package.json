{
  "name": "hostel-multi-tenant",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "turbo": "^2.1.3",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.8.1",
  "dependencies": {
    "@supabase/ssr": "^0.10.2"
  }
}
